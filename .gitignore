# Cartelle dati locali
# I dati scaricati e gli output generati dalla pipeline non vengono versionati.
# R2 è il posto in cui pubblicare i file JSON e Parquet finali.
data/raw/*
data/intermediate/*
data/processed/*
data/dashboard_json/*

# Mantiene la struttura delle cartelle nel repository
!data/raw/.gitkeep
!data/intermediate/.gitkeep
!data/processed/.gitkeep
!data/dashboard_json/.gitkeep

# File dati pesanti o generati
*.parquet
*.csv
*.xlsx
*.xls
*.zip
*.jsonl
*.db
*.duckdb

# Ambiente locale
.env
.envrc
.venv/
venv/
ENV/
env/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Sistema operativo
.DS_Store
Thumbs.db
