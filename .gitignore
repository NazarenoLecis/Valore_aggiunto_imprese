# Cartelle dati locali
# I dati scaricati e gli output generati dalla pipeline non vengono versionati.
# Il repository genera CSV, JSON e grafici locali. La pubblicazione esterna è fuori perimetro.
data/raw/*
data/intermediate/*
data/processed/*
data/processed_csv/*
data/processed_json/*
data/validation/*
outputs/charts/*

# Mantiene la struttura delle cartelle nel repository
!data/raw/.gitkeep
!data/intermediate/.gitkeep
!data/processed/.gitkeep
!data/processed_csv/.gitkeep
!data/processed_json/.gitkeep
!data/validation/.gitkeep
!outputs/charts/.gitkeep

# File dati pesanti o generati
*.csv
*.xlsx
*.xls
*.zip
*.jsonl
*.db
*.duckdb

# Ambiente locale
.env
.envrc
.venv/
venv/
ENV/
env/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Sistema operativo
.DS_Store
Thumbs.db
